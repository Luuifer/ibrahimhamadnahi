<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Ibrahim Hamad — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0B1120;
    --navy-mid: #111827;
    --white: #FFFFFF;
    --gray-light: #F7F8FA;
    --gray-border: #E5E7EB;
    --gray-text: #6B7280;
    --blue: #2563EB;
    --blue-light: #3B82F6;
    --teal: #38BDF8;
    --teal-dark: #0EA5E9;
    --text-dark: #111827;
    --text-mid: #374151;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    color: var(--text-dark);
    background: var(--white);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5%;
    height: 64px;
    background: rgba(11,17,32,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.3s;
  }
  .nav-logo {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700; font-size: 1.15rem;
    color: var(--white);
    letter-spacing: -0.02em;
  }
  .nav-logo span { color: var(--teal); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-size: 0.875rem; font-weight: 500;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--teal); }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
  .hamburger span { display: block; width: 24px; height: 2px; background: rgba(255,255,255,0.8); border-radius: 2px; transition: 0.3s; }

  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .nav-links {
      display: none; position: fixed; top: 64px; left: 0; right: 0;
      flex-direction: column; gap: 0;
      background: var(--navy); padding: 1rem 0;
    }
    .nav-links.open { display: flex; }
    .nav-links a { padding: 0.75rem 5%; display: block; }
  }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    background: var(--navy);
    display: flex; align-items: center;
    padding: 100px 5% 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-grid-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(56,189,248,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56,189,248,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-glow {
    position: absolute; top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(37,99,235,0.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-glow-2 {
    position: absolute; bottom: -150px; left: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(56,189,248,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content { position: relative; max-width: 820px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(56,189,248,0.1);
    border: 1px solid rgba(56,189,248,0.25);
    border-radius: 100px;
    padding: 0.35rem 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem; color: var(--teal);
    margin-bottom: 1.75rem;
    animation: fadeInUp 0.6s ease both;
  }
  .hero-badge::before { content: ''; display: block; width: 6px; height: 6px; background: var(--teal); border-radius: 50%; animation: pulse 2s infinite; }

  .hero-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    animation: fadeInUp 0.6s ease 0.1s both;
  }
  .hero-name span { color: var(--teal); }

  .hero-typewriter {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    color: var(--teal);
    margin-bottom: 1.75rem;
    min-height: 1.8em;
    animation: fadeInUp 0.6s ease 0.2s both;
  }
  .hero-typewriter::before { content: '> '; color: rgba(56,189,248,0.45); }
  .cursor { display: inline-block; width: 2px; height: 1.1em; background: var(--teal); vertical-align: text-bottom; animation: blink 0.9s step-end infinite; margin-left: 2px; }

  .hero-text {
    font-size: clamp(0.95rem, 1.8vw, 1.05rem);
    color: rgba(255,255,255,0.6);
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 2.25rem;
    animation: fadeInUp 0.6s ease 0.3s both;
  }

  .hero-cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--blue);
    color: var(--white);
    font-family: 'Inter', sans-serif;
    font-weight: 600; font-size: 0.95rem;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(37,99,235,0.35);
    animation: fadeInUp 0.6s ease 0.4s both;
  }
  .hero-cta:hover { background: var(--blue-light); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(37,99,235,0.45); }

  .hero-stats {
    display: flex; gap: 2.5rem; margin-top: 3rem;
    animation: fadeInUp 0.6s ease 0.5s both;
  }
  .stat { }
  .stat-num { font-family: 'Space Grotesk', sans-serif; font-size: 1.6rem; font-weight: 700; color: var(--white); }
  .stat-label { font-size: 0.75rem; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px; }

  /* ── SECTION BASE ── */
  section { padding: 90px 5%; }
  .section-alt { background: var(--gray-light); }

  .section-label {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.6rem;
  }
  .section-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--text-dark);
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .section-divider {
    width: 40px; height: 3px;
    background: linear-gradient(90deg, var(--blue), var(--teal));
    border-radius: 3px;
    margin-bottom: 2.5rem;
  }

  .container { max-width: 1100px; margin: 0 auto; }

  /* ── ABOUT ── */
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
  }
  .about-text p {
    font-size: 1rem; line-height: 1.8; color: var(--text-mid); margin-bottom: 1rem;
  }
  .about-highlights { display: flex; flex-direction: column; gap: 1rem; }
  .highlight-card {
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex; align-items: flex-start; gap: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .highlight-card:hover { border-color: var(--blue); box-shadow: 0 4px 20px rgba(37,99,235,0.08); transform: translateY(-2px); }
  .h-icon { font-size: 1.4rem; line-height: 1; flex-shrink: 0; margin-top: 2px; }
  .h-text strong { display: block; font-weight: 600; font-size: 0.9rem; color: var(--text-dark); margin-bottom: 2px; }
  .h-text span { font-size: 0.83rem; color: var(--gray-text); }

  @media (max-width: 768px) { .about-grid { grid-template-columns: 1fr; gap: 2rem; } }

  /* ── PROJECTS ── */
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }
  .project-card {
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    position: relative; overflow: hidden;
  }
  .project-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue), var(--teal));
    opacity: 0; transition: opacity 0.2s;
  }
  .project-card:hover { border-color: transparent; box-shadow: 0 8px 32px rgba(37,99,235,0.12); transform: translateY(-4px); }
  .project-card:hover::before { opacity: 1; }
  .project-icon { font-size: 2rem; margin-bottom: 1rem; }
  .project-title { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 1.05rem; color: var(--text-dark); margin-bottom: 0.6rem; }
  .project-desc { font-size: 0.875rem; color: var(--gray-text); line-height: 1.7; }

  /* ── EDUCATION ── */
  .edu-card {
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: 14px;
    padding: 2rem 2.25rem;
    display: flex; align-items: flex-start; gap: 1.5rem;
    max-width: 720px;
  }
  .edu-icon {
    width: 52px; height: 52px; border-radius: 12px;
    background: linear-gradient(135deg, var(--blue), var(--teal));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; flex-shrink: 0;
  }
  .edu-title { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1.1rem; color: var(--text-dark); }
  .edu-school { font-size: 0.95rem; color: var(--blue); font-weight: 500; margin: 4px 0; }
  .edu-date { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--gray-text); margin-bottom: 0.75rem; }
  .edu-desc { font-size: 0.875rem; color: var(--text-mid); line-height: 1.7; }

  /* ── EXPERIENCE ── */
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before { content: ''; position: absolute; left: 7px; top: 8px; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--blue), var(--teal)); border-radius: 2px; }
  .tl-item { position: relative; margin-bottom: 2.5rem; }
  .tl-dot {
    position: absolute; left: -2rem; top: 6px;
    width: 16px; height: 16px; border-radius: 50%;
    background: var(--white);
    border: 3px solid var(--blue);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.15);
  }
  .tl-card {
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .tl-card:hover { border-color: var(--blue); box-shadow: 0 4px 20px rgba(37,99,235,0.08); }
  .tl-role { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1rem; color: var(--text-dark); }
  .tl-date { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--teal-dark); margin: 4px 0 0.75rem; }
  .tl-list { list-style: none; }
  .tl-list li { font-size: 0.875rem; color: var(--text-mid); line-height: 1.7; padding-left: 1rem; position: relative; }
  .tl-list li::before { content: '›'; position: absolute; left: 0; color: var(--blue); font-weight: 700; }

  /* ── SKILLS ── */
  .skills-wrapper { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
  .skill-group {
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .skill-group:hover { border-color: var(--blue); box-shadow: 0 4px 16px rgba(37,99,235,0.08); }
  .skill-group-title { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 0.85rem; color: var(--text-dark); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .skill-group-title span { font-size: 1.1rem; }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    background: var(--gray-light);
    color: var(--text-mid);
    font-size: 0.78rem; font-weight: 500;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    border: 1px solid var(--gray-border);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .tag:hover { background: rgba(37,99,235,0.08); color: var(--blue); border-color: rgba(37,99,235,0.3); }

  /* ── CONTACT ── */
  .contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 3.5rem; align-items: start; }
  .contact-info { display: flex; flex-direction: column; gap: 1rem; }
  .contact-item {
    display: flex; align-items: center; gap: 1rem;
    background: var(--white);
    border: 1px solid var(--gray-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .contact-item:hover { border-color: var(--blue); box-shadow: 0 4px 16px rgba(37,99,235,0.08); }
  .c-icon { width: 40px; height: 40px; border-radius: 8px; background: linear-gradient(135deg, var(--blue), var(--teal)); display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
  .c-label { font-size: 0.72rem; color: var(--gray-text); text-transform: uppercase; letter-spacing: 0.08em; }
  .c-value { font-size: 0.9rem; font-weight: 500; color: var(--text-dark); }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.8rem; font-weight: 500; color: var(--text-mid); }
  .form-group input, .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--gray-border);
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: var(--text-dark);
    background: var(--white);
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
  }
  .form-group input:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .form-group textarea { min-height: 130px; }
  .btn-submit {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    background: var(--blue);
    color: var(--white);
    font-family: 'Inter', sans-serif;
    font-weight: 600; font-size: 0.95rem;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    border: none; cursor: pointer;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(37,99,235,0.3);
    align-self: flex-start;
  }
  .btn-submit:hover { background: var(--blue-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,99,235,0.4); }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    .form-row { grid-template-columns: 1fr; }
  }

  /* ── FOOTER ── */
  footer {
    background: var(--navy);
    padding: 2rem 5%;
    text-align: center;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.35);
    font-family: 'JetBrains Mono', monospace;
  }
  footer span { color: rgba(56,189,248,0.6); }

  /* ── ANIMATIONS ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; }
    .hero-cta, .hero-badge, .hero-name, .hero-typewriter, .hero-text, .hero-stats { animation: none; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">IH<span>.</span></div>
  <ul class="nav-links" id="navLinks">
    <li><a href="#about">About</a></li>
